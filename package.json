{
  "name": "@middag-io/react",
  "version": "0.35.1",
  "type": "module",
  "description": "MIDDAG shared React UI library for Moodle, WordPress and other Inertia hosts",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/middag-io/middag-react.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "middag-react": "./bin/middag-react.js"
  },
  "main": "dist-lib/middag-react.js",
  "module": "dist-lib/middag-react.js",
  "types": "dist-lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-lib/middag-react.js",
      "types": "./dist-lib/index.d.ts"
    },
    "./style.css": "./dist-lib/middag-react.css",
    "./theme.css": "./src/theme.css",
    "./reui/*": {
      "types": "./dist-lib/components/reui/*.d.ts",
      "import": "./dist-lib/components/reui/*.js",
      "default": "./dist-lib/components/reui/*.js"
    },
    "./reui/*.tsx": {
      "types": "./dist-lib/components/reui/*.d.ts",
      "import": "./dist-lib/components/reui/*.js",
      "default": "./dist-lib/components/reui/*.js"
    },
    "./i18n/*": {
      "types": "./dist-lib/i18n/*.d.ts",
      "import": "./dist-lib/i18n/*.js",
      "default": "./dist-lib/i18n/*.js"
    },
    "./i18n/locales/*.json": "./dist-lib/i18n/locales/*.json",
    "./blocks/*": "./src/base/blocks/*",
    "./form/*": "./src/base/form/*",
    "./partials/*": "./src/base/partials/*",
    "./lib/*": {
      "types": "./dist-lib/lib/*.d.ts",
      "import": "./dist-lib/lib/*.js",
      "default": "./dist-lib/lib/*.js"
    },
    "./shell/*": {
      "types": "./dist-lib/base/shell/*.d.ts",
      "import": "./dist-lib/base/shell/*.js",
      "default": "./dist-lib/base/shell/*.js"
    },
    "./utils/*": {
      "types": "./dist-lib/base/utils/*.d.ts",
      "import": "./dist-lib/base/utils/*.js",
      "default": "./dist-lib/base/utils/*.js"
    },
    "./theme/*": {
      "types": "./dist-lib/base/theme/*.d.ts",
      "import": "./dist-lib/base/theme/*.js",
      "default": "./dist-lib/base/theme/*.js"
    },
    "./theme/*.css": "./dist-lib/base/theme/*.css",
    "./theme/*.txt": "./dist-lib/base/theme/*.txt",
    "./themes/classic.css": "./src/base/theme/themes/classic.css",
    "./schemas/*.json": "./docs/public/schemas/*.json"
  },
  "files": [
    "dist-lib",
    "dist-mock",
    "bin",
    "src/theme.css",
    "src/base",
    "src/app",
    "src/contracts",
    "src/components/reui",
    "src/components/ui",
    "src/lib",
    "src/i18n",
    "src/assets",
    "docs/public/schemas"
  ],
  "scripts": {
    "build": "vite build && npm run build:subpaths && node scripts/patch-esm.mjs && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:subpaths": "vite build --config vite.subpaths.config.ts",
    "dev": "vite --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:demo": "tsc -p demo/tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:format": "npm run format && eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"demo/**/*.{ts,tsx,css}\" \"scripts/**/*.{mjs,js,ts}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"demo/**/*.{ts,tsx,css}\" \"scripts/**/*.{mjs,js,ts}\" \"tests/**/*.{ts,tsx}\"",
    "prepare": "git config core.hooksPath .githooks",
    "sync:examples": "bash scripts/sync-reui-examples.sh && npm run format",
    "gen:contracts": "node scripts/gen-contracts.mjs",
    "gen:contracts:check": "node scripts/gen-contracts.mjs --check",
    "doctor": "bash scripts/doctor.sh",
    "i18n:extract": "i18next --config i18next-parser.config.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run typecheck:tests && npm run typecheck:demo && npm run lint && npm run format:check",
    "docs:build": "node scripts/prepare-docs-payload.mjs",
    "docs:verify": "node scripts/verify-docs-payload.mjs"
  },
  "peerDependencies": {
    "@inertiajs/core": "^3.0.0",
    "@inertiajs/react": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/figtree": "^5.2.10",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@lexical/link": "0.45.0",
    "@lexical/list": "0.45.0",
    "@lexical/react": "0.45.0",
    "@lexical/rich-text": "0.45.0",
    "@lexical/selection": "0.45.0",
    "@lexical/utils": "0.45.0",
    "@lottiefiles/dotlottie-react": "^0.19.0",
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/validator": "^13.15.10",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "lexical": "0.45.0",
    "libphonenumber-js": "^1.12.42",
    "little-date": "^1.2.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "nprogress": "^0.2.0",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-phone-number-input": "^3.4.16",
    "react-resizable-panels": "^4.11.0",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "validator": "^13.15.35",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@inertiajs/core": "^3.0.0",
    "@inertiajs/react": "^3.0.0",
    "@lexical/headless": "0.45.0",
    "@tailwindcss/cli": "4.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "country-flag-icons": "^1.6.17",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "i18next-parser": "^9.4.0",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "json-schema-to-zod": "^2.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-router": "^7.14.2",
    "tailwindcss": "^4.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.58.2",
    "vite": "8.0.5",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.5"
  },
  "homepage": "https://ui-docs.middag.io",
  "bugs": {
    "url": "https://github.com/middag-io/middag-react/issues"
  }
}
