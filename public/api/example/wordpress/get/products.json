{
  "description": "Example: GET /api/example/wordpress/get/products.json -- Product catalog for a WordPress/WooCommerce storefront. Demonstrates the `stack` layout with a card_grid block using the 'store' variant. Actions use the current target/intent hierarchy. Shape validated (see tests/fixtures/public-api-contracts.test.ts).",
  "host": "wordpress",
  "method": "GET",
  "contract": {
    "version": "1",
    "shell": "product",
    "page": {
      "key": "products-catalog",
      "title": "Products",
      "breadcrumbs": [
        { "label": "Store", "href": "/store" },
        { "label": "Products" }
      ],
      "actions": [
        {
          "id": "add-product",
          "label": "Add Product",
          "intent": "primary",
          "icon": "plus",
          "target": { "kind": "link", "href": "/store/products/new" }
        },
        {
          "id": "import-products",
          "label": "Import",
          "intent": "secondary",
          "icon": "upload",
          "target": { "kind": "link", "href": "/store/products/import" }
        }
      ],
      "filterTabs": [
        { "key": "all", "label": "All Products", "badge": 24 },
        { "key": "published", "label": "Published", "badge": 18 },
        { "key": "draft", "label": "Draft", "badge": 4 },
        { "key": "out-of-stock", "label": "Out of Stock", "badge": 2 }
      ]
    },
    "layout": {
      "template": "stack",
      "regions": {
        "content": [
          {
            "type": "card_grid",
            "key": "products-grid",
            "data": {
              "columns": [
                { "key": "name", "label": "Product", "kind": "text" },
                { "key": "price", "label": "Price", "kind": "text" },
                { "key": "stock", "label": "Stock", "kind": "number" },
                { "key": "status", "label": "Status", "kind": "status" },
                { "key": "category", "label": "Category", "kind": "text" },
                { "key": "sales", "label": "Total Sales", "kind": "number" }
              ],
              "rows": [
                {
                  "id": "prod-1",
                  "name": "NR-10 Safety Certification Course",
                  "description": "Complete electrical safety training with official NR-10 certification upon completion.",
                  "price": "$249.00",
                  "stock": null,
                  "status": "Published",
                  "category": "Safety Training",
                  "sales": 847,
                  "image": "/images/placeholder-course.png",
                  "href": "/store/products/prod-1"
                },
                {
                  "id": "prod-2",
                  "name": "Leadership & Management Bundle",
